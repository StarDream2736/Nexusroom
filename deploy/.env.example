# ============================================================
# NexusRoom 环境变量
# ============================================================
# 使用方式：复制本文件为 .env，修改以下三项
# docker-compose.yml 会自动读取 .env 中的变量
# ============================================================

# 【必改】PostgreSQL 数据库密码（建议 16 位以上随机字符串）
DB_PASSWORD=your-secure-db-password

# 【必改】LiveKit API Key（需与 livekit.yaml 及 config.yaml 一致）
LIVEKIT_API_KEY=your-livekit-key

# 【必改】LiveKit API Secret（建议 32 位以上随机字符串）
LIVEKIT_API_SECRET=your-livekit-secret
